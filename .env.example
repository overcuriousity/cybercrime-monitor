# Copy to .env and fill in values. Also copy config/sources.yaml.example ->
# config/sources.yaml — the real file is gitignored (deployment-specific) so
# it's not committed, but the app won't start without it present locally.
#
# IMPORTANT: this app must run as a SINGLE uvicorn worker/process. APScheduler
# (scheduler.py), the in-memory source/llm health registries (health.py,
# llm/health.py), and the SSE fan-out (api/sse.py) are all process-local
# singletons with no cross-process coordination — running `--workers N>1`
# (or multiple systemd instances against the same DB) would run every
# collector/extraction/retention job N times and split SSE/health state
# randomly per request. Scale by running the collectors faster (lower
# interval_seconds in sources.yaml), not by adding workers.
DB_PATH=data/items.db
# Keep this on localhost and put a reverse proxy (with TLS) in front if you
# want the dashboard reachable publicly — don't bind 0.0.0.0 directly.
BIND_HOST=127.0.0.1
BIND_PORT=8000
TOR_SOCKS=socks5h://127.0.0.1:9050
LOG_LEVEL=INFO

# Required for admin-gated routes (force re-research, filtered items, the
# targeted-investigation trigger) — generate with e.g. `openssl rand -hex 32`.
# Leave empty to disable those endpoints entirely.
ADMIN_TOKEN=

# Gotify (optional — leave empty to disable push notifications)
GOTIFY_URL=
GOTIFY_TOKEN=

# ── LLM extraction layer ──────────────────────────────────────────────────────
# Structured-field extraction (crime type, victim, attribution, CVEs,
# significance) per item — the sole classification/alerting signal. Gotify
# "critical" alerts wait for extraction confirmation. Set LLM_BACKEND=none to
# disable entirely (no extractions, no alerts).
#
# PRIVACY: item text is sent to LLM_BASE_URL for extraction ("openai" mode)
# or to hermes-agent's configured provider ("hermes_cli" mode — check
# `hermes status` for which provider that actually is; may be a cloud API).
# The "openai" default below is a local LMStudio/vLLM instance — nothing
# leaves the machine in that mode.
#
# Set LLM_BACKEND=hermes_cli to route extraction/dedup through the
# locally-installed hermes-agent CLI instead of an HTTP endpoint — useful
# when there's no separate OpenAI-compatible server running but `hermes`
# already works. LLM_BASE_URL/LLM_API_KEY/LLM_MODEL are ignored in this mode.
LLM_BACKEND=openai
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_API_KEY=
LLM_MODEL=
LLM_BATCH_SIZE=10
LLM_INTERVAL_SECONDS=30
LLM_TIMEOUT_SECONDS=300
# A false_positive=true verdict below this confidence (0.0-1.0) is NOT
# trusted to suppress the item — it stays visible instead of silently
# dropping on a guess. 0.0 (default) trusts every verdict.
LLM_MIN_CONFIDENCE=0.0

# ── hermes-agent integration ──────────────────────────────────────────────────
# hermes-agent (Nous Research's self-improving agent CLI — install separately,
# https://hermes-agent.nousresearch.com) drives autonomous OSINT research on
# cases and self-healing of broken collectors. Both shell out to the `hermes`
# binary headless; see hermes/runner.py. Requires `hermes` on PATH and an
# already-configured model/provider (`hermes model`).
HERMES_BIN=hermes
HERMES_MODEL=
HERMES_TOOLSETS=web,browser
# Browsing-heavy runs (multiple searches + page fetches, sometimes a dark-web
# fetch via Tor) need real headroom — 900s was still observed timing out
# legitimate in-progress runs; give it more before raising it again.
HERMES_TIMEOUT_SECONDS=1200
# Bounded in-process retry for clearly-transient hermes failures (a single
# bad provider hop in a fallback chain, not a real outage) — see
# hermes/runner.py's _is_transient. Does NOT retry timeouts.
HERMES_MAX_RETRIES=1
HERMES_RETRY_BACKOFF_SECONDS=5.0
# Process-wide cap on concurrently-running hermes-agent subprocesses, shared
# by research/heal/investigate — sized against the primary backend's
# published rate limit (e.g. NVIDIA NIM: 0.83 req/s, 1M tokens/min as of
# 2026-06-21). See settings.py for the full sizing rationale before raising.
HERMES_MAX_CONCURRENT_RUNS=2
HERMES_RESEARCH_INTERVAL_SECONDS=120
# Cases pulled and dispatched concurrently per tick (actual parallelism
# capped by HERMES_MAX_CONCURRENT_RUNS, not this number) — see
# research/agent.py's run_research_batch.
HERMES_RESEARCH_BATCH_SIZE=8
# A completed research run blocks the same case from natural re-research
# for 24h (hardcoded — see research/agent.py's _RESEARCH_COOLDOWN_HOURS).
# A *failed* run (timeout, hermes error, malformed response) instead uses
# this much shorter cooldown — a failure means no answer was produced, so
# locking the case out for a full day on a transient/backend issue just
# wastes its slot in the queue.
RESEARCH_FAILURE_RETRY_HOURS=2
HERMES_HEAL_INTERVAL_SECONDS=3600
HERMES_HEAL_ERROR_THRESHOLD=5

# Investigator-triggered targeted research (POST /api/investigations) — see
# research/investigate.py. Interval is a safety net; the endpoint nudges the
# job to run immediately on submit. 0 disables the job entirely.
HERMES_INVESTIGATE_INTERVAL_SECONDS=900
# Findings are only integrated (case + items + source candidates) when Hermes
# reports found=true AND at least this much confidence (0.0-1.0).
INVESTIGATE_MIN_CONFIDENCE=0.5
# A transient investigation failure (rate-limited/empty-response provider
# hop — see hermes/runner.py's _is_transient) is re-queued with this
# cooldown instead of going straight to terminal "failed", up to
# INVESTIGATE_MAX_ATTEMPTS retries (INVESTIGATE_MAX_ATTEMPTS + 1 total runs,
# including the initial try). Short relative to RESEARCH_FAILURE_RETRY_HOURS
# because investigations are user-initiated and time-sensitive.
INVESTIGATE_MAX_ATTEMPTS=3
INVESTIGATE_FAILURE_RETRY_MINUTES=15

# Truly agentic self-improvement loop (research/heal.py, research/discover.py,
# sources/writer.py, sources/value.py): validated heal fixes are written
# straight to sources.yaml and the collector is live-rescheduled, low-value
# sources are auto-disabled/removed, and a discovery job searches for new RSS/
# Atom sources to add — all gated by a relative investigation-value judgement,
# not a static confidence number. Set to false to fall back to advisory-only
# (proposals still logged to source_heal_proposals, never applied).
SOURCE_AUTOAPPLY_ENABLED=true
HERMES_DISCOVER_INTERVAL_SECONDS=21600
SOURCE_PROBATION_DAYS=7
SOURCE_PRUNE_GRACE_DAYS=5
SOURCE_VALUE_REFRESH_INTERVAL_SECONDS=1800

# ── Semantic search / embeddings ──────────────────────────────────────────────
# Powers the "semantic" search mode (vs. the always-available "keyword"
# substring mode) over case/item titles+summaries. Independent of LLM_BACKEND
# above — embeddings use a different endpoint shape (/embeddings).
#
# EMBED_BACKEND=local (default): fastembed running EMBED_LOCAL_MODEL
# in-process — no external server, multilingual, fully on-machine. The model
# (~2GB) downloads once on first use; needs internet for that one time only.
# EMBED_BACKEND=openai: calls an OpenAI-compatible /embeddings endpoint —
# reuses LLM_BASE_URL/LLM_API_KEY unless EMBED_BASE_URL/EMBED_API_KEY are set
# below. EMBED_BACKEND=none disables semantic search entirely (keyword search
# still works as before).
#
# INTEGRITY: changing EMBED_BACKEND or the model triggers a full vector
# re-index on next startup (old vectors are never mixed with new-backend
# vectors) — expect a burst of re-embedding activity right after such a
# change. See embeddings/index.py.
EMBED_BACKEND=local
EMBED_LOCAL_MODEL=BAAI/bge-m3
# Keep this on persistent disk, not left to fastembed's OS-temp-dir default —
# if /tmp is tmpfs (RAM-backed) on your deployment, the ~2GB model cache
# would otherwise permanently occupy that much RAM and re-download on every
# reboot.
EMBED_LOCAL_CACHE_DIR=data/embed_cache
EMBED_BASE_URL=
EMBED_API_KEY=
EMBED_MODEL=text-embedding-3-small
EMBED_BATCH_SIZE=32
EMBED_INTERVAL_SECONDS=60

# CISA Known Exploited Vulnerabilities catalog — cached locally and refreshed
# on this interval; see enrich/kev.py.
KEV_FEED_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
KEV_REFRESH_INTERVAL_SECONDS=86400

# Items older than this many days are pruned daily (effective-critical items
# are NEVER pruned, regardless of age — see db.py:prune_old_items). 0
# disables retention entirely.
RETENTION_DAYS=90

# Public-dashboard DoS resistance — this app is meant for one analyst's own
# browser tabs but is commonly reachable publicly (see ADMIN_TOKEN above).
# SSE_MAX_SUBSCRIBERS caps concurrent live-feed connections;
# RATE_LIMIT_PER_MINUTE is a per-IP token bucket on /api/* (0 disables it).
SSE_MAX_SUBSCRIBERS=50
RATE_LIMIT_PER_MINUTE=120
