# Copy to .env and fill in values. Also copy config/keywords.yaml.example ->
# config/keywords.yaml and config/sources.yaml.example -> config/sources.yaml
# — the real files are gitignored (keywords.yaml can carry your investigation
# TARGET indicators; sources.yaml is deployment-specific) so they're not
# committed, but the app won't start without them present locally.
#
# IMPORTANT: this app must run as a SINGLE uvicorn worker/process. APScheduler
# (scheduler.py), the in-memory source/classifier health registries
# (health.py, classifier/health.py), and the SSE fan-out (api/sse.py) are all
# process-local singletons with no cross-process coordination — running
# `--workers N>1` (or multiple systemd instances against the same DB) would
# run every collector/classifier/retention job N times and split SSE/health
# state randomly per request. Scale by running the collectors faster
# (lower interval_seconds in sources.yaml), not by adding workers.
DB_PATH=data/items.db
# Keep this on localhost and put a reverse proxy (with TLS) in front if you
# want the dashboard reachable publicly — don't bind 0.0.0.0 directly.
BIND_HOST=127.0.0.1
BIND_PORT=8000
TOR_SOCKS=socks5h://127.0.0.1:9050
LOG_LEVEL=INFO

# Required to view/edit keyword rules (GET/PUT /api/keywords) — generate with
# e.g. `openssl rand -hex 32`. Leave empty to disable the keywords endpoints
# entirely (recommended default once the dashboard is public, since GET
# would otherwise leak your TARGET indicators and PUT writes regex to disk).
ADMIN_TOKEN=

# Gotify (optional — leave empty to disable push notifications)
GOTIFY_URL=
GOTIFY_TOKEN=

# LLM classifier — assigns real priority per item and flags false positives,
# replacing the regex matcher's priority as the authoritative signal once an
# item is classified. Gotify "critical" alerts wait for classifier
# confirmation (with a fallback-alert safety net if the backend is down —
# see CLASSIFIER_FALLBACK_ALERT_MINUTES). Set CLASSIFIER_BACKEND=none to
# disable entirely and restore pre-classifier behavior (instant Gotify on
# regex match, nothing sent anywhere).
#
# PRIVACY: item text (which can include your TARGET indicators from
# config/keywords.yaml) is sent to CLASSIFIER_BASE_URL for classification.
# The default below is a local LMStudio instance — nothing leaves the
# machine. Pointing this at a third-party API sends investigation content
# to that party.
CLASSIFIER_BACKEND=openai
CLASSIFIER_BASE_URL=http://127.0.0.1:1234/v1
CLASSIFIER_API_KEY=
CLASSIFIER_MODEL=
CLASSIFIER_BATCH_SIZE=10
CLASSIFIER_INTERVAL_SECONDS=30
CLASSIFIER_TIMEOUT_SECONDS=90
CLASSIFIER_FALLBACK_ALERT_MINUTES=10
# A false_positive=true verdict below this confidence (0.0-1.0) is NOT
# trusted to suppress the item — it stays visible instead of silently
# dropping on a guess. 0.0 (default) trusts every verdict, matching
# pre-threshold behavior. Try 0.5-0.7 if you notice real incidents getting
# filtered by a low-confidence call.
CLASSIFIER_MIN_CONFIDENCE=0.0

# Items older than this many days are pruned daily (critical-priority and
# "target"-tagged items are NEVER pruned, regardless of age — see
# db.py:prune_old_items). 0 disables retention entirely.
RETENTION_DAYS=90

# Public-dashboard DoS resistance — this app is meant for one analyst's own
# browser tabs but is commonly reachable publicly (see ADMIN_TOKEN above).
# SSE_MAX_SUBSCRIBERS caps concurrent live-feed connections;
# RATE_LIMIT_PER_MINUTE is a per-IP token bucket on /api/* (0 disables it).
SSE_MAX_SUBSCRIBERS=50
RATE_LIMIT_PER_MINUTE=120
